# ---------------------------------------------------------------------------
# pipeline — environment variables
# Copy to .env.local for local dev; set the same vars in the Vercel dashboard.
# Do NOT put real values in this file — it is committed to git.
# ---------------------------------------------------------------------------

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used by the seed script and any privileged server task.
# NEVER expose this to the client. (Project Settings -> API -> service_role)
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (server-side only). Model: claude-sonnet-4-6
ANTHROPIC_API_KEY=

# Resend — daily digest email
RESEND_API_KEY=
DIGEST_TO_EMAIL=
# Verified sender in Resend. Default sandbox: pipeline <onboarding@resend.dev>
DIGEST_FROM_EMAIL=
# Optional: pin the digest to a specific auth user (else first auth user)
DIGEST_USER_ID=

# Cron + signed one-click digest links (Vercel Cron sends Bearer CRON_SECRET)
CRON_SECRET=
# Optional; falls back to CRON_SECRET for HMAC of snooze/touched links
DIGEST_SIGNING_SECRET=

# Base URL used for magic-link auth redirects AND digest deep links.
# Local: http://localhost:3002  |  Prod: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3002
