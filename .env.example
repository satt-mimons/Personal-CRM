# ---------------------------------------------------------------------------
# pipeline — environment variables
# Copy to .env.local for local dev; set the same vars in the Vercel dashboard.
# Do NOT put real values in this file — it is committed to git.
# ---------------------------------------------------------------------------

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used by the seed script and any privileged server task.
# NEVER expose this to the client. (Project Settings -> API -> service_role)
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (server-side only). Model: claude-sonnet-4-6
ANTHROPIC_API_KEY=

# Resend — email. Not used yet; wired in a later prompt.
RESEND_API_KEY=

# Base URL used for magic-link auth redirects. MUST match the dev port
# (pipeline runs on 3002 via `next dev -p 3002`) and be added to Supabase
# Auth -> URL Configuration -> Redirect URLs.
# Local: http://localhost:3002  |  Prod: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3002
